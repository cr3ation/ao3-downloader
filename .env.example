# Copy this file to .env and edit as needed:  cp .env.example .env
#
# .env is git-ignored, so your local paths and settings survive every git pull.
# Every value below is optional — without a .env file the defaults shown here
# are used, so `docker compose up -d --build` works straight after a clone.

# ---------------------------------------------------------------- Paths & port

# Where downloaded e-books are written. Point this at the folder Calibre
# watches for automatic adding, e.g. /volume1/calibre/autoadd on a NAS.
DOWNLOADS_PATH=./downloads

# Where the app keeps metadata.json (its record of what has been downloaded).
# Must NOT be inside the Calibre watch folder.
CONFIG_PATH=./config

# Host port for the web UI.
PORT=8067

# ---------------------------------------------------------------- User & time

# Run as this user/group so downloaded files are owned by you.
# Find your values on the host with: id -u && id -g
PUID=1000
PGID=1000

TZ=Europe/Stockholm

# ---------------------------------------------------------------- Accounts & sessions

# Used ONLY to seed the first administrator, the very first time the app starts
# with an empty database. Changing them later does nothing — manage accounts in
# the System tab instead.
ADMIN_USERNAME=admin
# Leave ADMIN_PASSWORD blank to have a strong one generated and printed once to
# `docker compose logs ao3-downloader`. Set it to choose your own.
ADMIN_PASSWORD=

# Break-glass recovery for a forgotten password: set this, restart, and the
# ADMIN_USERNAME account is reset to it and promoted to admin. Blank it again
# and restart afterwards — it re-applies on every boot while set.
ADMIN_PASSWORD_RESET=

# Whether the session cookie gets the Secure flag.
#   auto  = only over HTTPS (correct for a plain-HTTP LAN)
#   true  = always — REQUIRED behind HTTPS, but breaks login over plain http://
#   false = never
SESSION_COOKIE_SECURE=auto
SESSION_TTL_DAYS=30

# Only needed behind a reverse proxy. PUBLIC_BASE_URL hard-overrides the OIDC
# redirect URI (e.g. https://ao3.example.com); FORWARDED_ALLOW_IPS lets uvicorn
# trust X-Forwarded-Proto from the proxy (its container IP, or * on a trusted net).
PUBLIC_BASE_URL=
FORWARDED_ALLOW_IPS=127.0.0.1

# ---------------------------------------------------------------- Behaviour

# Save files directly in the downloads root instead of per-search subfolders.
# Must stay true for Calibre's automatic adding, which does not scan subfolders.
FLAT_DOWNLOADS=true

# Tag embedded in every downloaded EPUB; Calibre imports it as a tag.
# Set to an empty value to disable.
EPUB_TAG=Fanfiction

# ---------------------------------------------------------------- Rate limiting

# Random delay range (seconds) between AO3 requests. Be generous — AO3 is a
# donation-funded nonprofit and rate-limits aggressively.
AO3_MIN_DELAY=3
AO3_MAX_DELAY=6

# Retries per request on 429/5xx/network errors, and backoff behaviour.
MAX_RETRIES=5
RETRY_BACKOFF_BASE=30
RETRY_BACKOFF_CAP=600
RETRY_AFTER_CAP=1800
REQUEST_TIMEOUT=60

# Caps on how much a single search may fetch.
MAX_RESULTS_CAP=500
MAX_PAGES=50
